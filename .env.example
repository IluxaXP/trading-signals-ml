# .env.example
# Настройки режимов работы воркера
# Скопируйте этот файл в .env и отредактируйте под нужный режим.
# Файл .env не должен попадать в репозиторий (уже в .gitignore).

# ------------------------------
# ОБЩИЕ ПЕРЕМЕННЫЕ
# ------------------------------

# Включает логирование сырых окон признаков в CSV (папка integration/logs/)
# LOG_FEATURES=true

# Интервал опроса API в секундах (по умолчанию: 60 в PRODUCTION, 5 в DEMO)
# POLL_INTERVAL=60

# Источник сигнала (ml_shadow – теневой режим, ml – продакшн)
# По умолчанию: ml_shadow
# SIGNAL_SOURCE=ml_shadow

# ------------------------------
# РЕЖИМ 1 – только локальный JSON (мок-сервер)
# Данные и сигналы направляются в локальный мок-сервер (http://localhost:3000).
# ------------------------------
# USE_MOCK=true
# LOG_FEATURES=true   # опционально
# (остальные переменные API не используются)

# ------------------------------
# РЕЖИМ 2 – данные с реального API, сигналы в локальный мок
# Данные получаем с реальной платформы, сигналы отправляем в мок-сервер.
# ------------------------------
# API_BASE_URL=https://your-platform.com
# API_USERNAME=dataset
# API_PASSWORD=your_password
# SIGNAL_TO_MOCK=true
# LOG_FEATURES=true
# POLL_INTERVAL=60
# SIGNAL_SOURCE=ml_shadow

# ------------------------------
# РЕЖИМ 3 – данные с реального API, сигналы туда же (теневой режим)
# Полноценное тестирование интеграции без влияния на торговлю.
# ------------------------------
# API_BASE_URL=https://your-platform.com
# API_USERNAME=operator
# API_PASSWORD=your_password
# SIGNAL_SOURCE=ml_shadow
# LOG_FEATURES=true
# POLL_INTERVAL=60

# ------------------------------
# РЕЖИМ 4 – полноценный продакшн
# Реальная отправка сигналов с источником ml.
# ------------------------------
# API_BASE_URL=https://your-platform.com
# API_USERNAME=operator
# API_PASSWORD=your_password
# SIGNAL_SOURCE=ml
# LOG_FEATURES=false
# POLL_INTERVAL=60

# =============================================
# Примечания:
# - В режимах 2 и 3 профиль dataset имеет право только на чтение данных.
# - Для отправки сигналов (POST /ingest) требуется профиль operator.
# - Переменная USE_MOCK имеет приоритет: если она true, все остальные игнорируются.
# - SIGNAL_TO_MOCK переопределяет адрес отправки сигналов на localhost:3000.